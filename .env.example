# PostgreSQL connection string (run: bash scripts/create-apex-db.sh to create)
DATABASE_URL=postgresql://apex_user:password@wbb-prod.c81qkua4c3e2.us-east-1.rds.amazonaws.com:5432/apex?sslmode=require

# AWS credentials (use a dedicated IAM user with SES + SNS + SQS permissions)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Created by setup_aws.py — run that once first
SES_CONFIG_SET=apex-campaigns
SES_EVENTS_QUEUE_URL=

# SMS provider: "mailchimp" (default) or "pinpoint"
SMS_PROVIDER=mailchimp
SMS_ORIGINATING_NUMBER=+1XXXXXXXXXX   # originating number (shared by all providers)

# Mailchimp Transactional / Mandrill (used when SMS_PROVIDER=mailchimp)
# Endpoint: POST https://mandrillapp.com/api/1.1/messages/send-sms
MAILCHIMP_TRANSACTIONAL_API_KEY=
# Consent type required by Mandrill: "onetime", "recurring", or "recurring-no-confirm"
MAILCHIMP_SMS_CONSENT=recurring

# AWS Pinpoint (used when SMS_PROVIDER=pinpoint — requires 10DLC approval)
PINPOINT_APPLICATION_ID=
SMS_SENDER_ID=ApexEnergy

# Unsubscribe support
UNSUBSCRIBE_SECRET=replace-with-a-random-secret
UNSUBSCRIBE_BASE_URL=https://windowsbyburkhardt.com/unsubscribe

# Office 365 SMTP credentials (used by send_outlook.py)
# Use your O365 password, or an app password if MFA is enabled on the account
SMTP_USERNAME=chris.burkhardt@apexenergygroup.com
SMTP_PASSWORD=
